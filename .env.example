# 数据库配置
# PostgreSQL 必须使用 asyncpg：postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_system
# 开发环境默认 SQLite（无需改）
DATABASE_URL=sqlite+aiosqlite:///./trading_system.db

# TradingView Webhook
TV_WEBHOOK_SECRET=your_webhook_secret_here

# 交易所配置（Phase 1.0 固定 1 家交易所 + 1 种产品形态）
EXCHANGE_NAME=okx  # 固定值：binance | okx | bybit
EXCHANGE_SANDBOX=true  # true=Paper Trading, false=实盘
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
PRODUCT_TYPE=perp  # 固定值：spot | perp

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_DATABASE=true

# 应用配置
APP_ENV=development  # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# Docker 镜像源（可选，国内拉取失败或 403 时可设，如 docker.1ms.run）
# DOCKER_MIRROR=docker.1ms.run
